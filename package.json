{
  "name": "@viocha/esm-pkg",
  "version": "1.1.0",
  "description": "Prebuilt browser ESM bundles for React, antd, clsx, lucide-react, htm, and shadcn/ui.",
  "keywords": [
    "esm",
    "browser",
    "importmap",
    "react",
    "antd",
    "shadcn"
  ],
  "homepage": "https://viocha.github.io/esm-pkg/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viocha/esm-pkg.git"
  },
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.18.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./react-all": "./dist/react-all.min.js",
    "./antd": "./dist/antd.min.js",
    "./ant-design-icons": "./dist/ant-design-icons.min.js",
    "./mui-icons-material": "./dist/mui-icons-material.min.js",
    "./primer-octicons-react": "./dist/primer-octicons-react.min.js",
    "./clsx": "./dist/clsx.min.js",
    "./lucide-react": "./dist/lucide-react.min.js",
    "./mui-material": "./dist/mui-material.min.js",
    "./primer-react": "./dist/primer-react.min.js",
    "./htm": "./dist/htm.min.js",
    "./shadcn": "./dist/shadcn.min.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build-all.mjs",
    "build:exports": "node ./scripts/generate-package-exports.mjs",
    "build:index": "node ./scripts/generate-examples-index.mjs",
    "build:shadcn": "node ./scripts/build-shadcn.mjs",
    "build:vendor": "node ./scripts/sync-example-vendor.mjs",
    "test:e2e": "pnpm run build && playwright test"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.0",
    "@babel/standalone": "^7.29.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@playwright/test": "^1.58.2",
    "@primer/octicons-react": "^19.22.0",
    "@primer/primitives": "11.5.1",
    "@primer/react": "38.15.0",
    "@tailwindcss/browser": "^4.2.1",
    "antd": "^6.3.2",
    "clsx": "^2.1.1",
    "esbuild": "^0.27.4",
    "htm": "^3.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
