{
  "name": "@viocha/esm-pkg",
  "version": "0.6.0",
  "description": "Prebuilt browser ESM bundles for React, antd, clsx, lucide-react, htm, and shadcn/ui.",
  "keywords": [
    "esm",
    "browser",
    "importmap",
    "react",
    "antd",
    "shadcn"
  ],
  "homepage": "https://github.com/viocha/esm-pkg#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viocha/esm-pkg.git"
  },
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.18.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./react-all": "./dist/react-all.min.js",
    "./antd": "./dist/antd.min.js",
    "./ant-design-icons": "./dist/ant-design-icons.min.js",
    "./clsx": "./dist/clsx.min.js",
    "./lucide-react": "./dist/lucide-react.min.js",
    "./htm": "./dist/htm.min.js",
    "./shadcn": "./dist/shadcn.min.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build-all.mjs",
    "build:shadcn": "node ./scripts/build-shadcn.mjs",
    "test:e2e": "pnpm run build && playwright test"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.0",
    "@playwright/test": "^1.58.2",
    "antd": "^6.3.2",
    "clsx": "^2.1.1",
    "esbuild": "^0.27.4",
    "htm": "^3.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
